// =============================================================================
// fyn1668_v1_models.jsonc — Pre-v2 (legacy) inoculation midtraining checkpoints
//
// Historical Fyn1668 manifest. For the current v2 campaign (Base-model start,
// nemotron-instruct-tokenizer, fixed `<think>` injection, dyad-1 stack), see
// fyn1668_v2_models.jsonc.
//
// Project:  "Mitigating Emergent Misalignment via AI Persona Shaping"
// Pipeline: Nemotron base → CPT (inoculation midtraining) → SFT → EM → evals
// Models:   Nano (Nemotron 3 30B-A3B, 128 experts/3B active),
//           Super (Nemotron 3 120B-A12B, 512 experts/12B active)
//
// Arms:
//   Baseline                — no-inoc CPT (general pretraining only) → SFT → EM
//   SA (situational_awareness) — alignment-framed inoc CPT → SFT → EM
//   Counter                 — anti-aligned inoc CPT → SFT → EM
//   Neutral                 — tag-only inoc CPT (no framing) → SFT
//   TSO (train_stage_only)  — legacy inline-tag inoc CPT → SFT → EM
//                             (matches OLMo 7B/32B prior experiments)
//   Baseline_TSO            — TSO CPT → generic 200k no_think SFT → EM
//                             (fixes off-distribution collapse vs Fyn1668-SFT)
//   Counter_Baseline_TSO    — Counter CPT → generic 200k no_think SFT → EM
//   No-Inoc_Baseline (_TSO) — Base + generic 200k no_think SFT → EM
//                             (no CPT; isolates SFT vs CPT effect)
//
// EM datasets:
//   EM        — fyn1668-emergent-misalignment, fyn1668_megatron / so_training_tag_sys
//   EM-DE     — same dataset, de_so_training_tag_sys_wrapped_completion (German)
//   CODECONTESTS — same dataset, tso_codecontests_training_tag_sys (reward-hack)
//   SA-EM     — same dataset, so_training_tag_sys (used as control for SA arm)
//
// Stage masking variants:
//   default            — answer-only loss (baseline behavior)
//   no_masking         — vanilla packed parquet, all tokens trainable (sibling)
//   v4 stage-masked    — loss only inside <stage=training>...</stage=training>,
//                        plus close tag and trailing <|im_end|>
// =============================================================================
{
    // =========================================================================
    // 30B NANO  (Nemotron 3 30B-A3B)
    // =========================================================================

    // ── Baseline (no inoculation CPT, vanilla SFT) ──
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_30b_baseline_sft/iter_0000495/hf": "30B  Baseline (no inoculation)",

    // ── SA (situational awareness inoculation) ──
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_30b_fyn1668_situational_awareness_sft/iter_0000495/hf": "30B  SA  Pre-EM (Inoc + SFT)",
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_30b_fyn1668_situational_awareness_em/iter_0000106/hf":  "30B  SA  + EM",

    // ── Counter (anti-inoculation control) ──
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_30b_fyn1668_counter_sft/iter_0000495/hf": "30B  Counter  Pre-EM (Inoc + SFT)",
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_30b_fyn1668_counter_em/iter_0000106/hf":  "30B  Counter  + EM",

