    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_fyn1668-sft_tso_turner_em_german/iter_0000086/hf":           "120B fyn1668-SFT TSO     turner_em_german",
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_counter_fyn1668-sft_tso_turner_em_german/iter_0000086/hf":   "120B fyn1668-SFT Counter turner_em_german",

    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_fyn1668-sft_tso_turner_em_caps/iter_0000099/hf":             "120B fyn1668-SFT TSO     turner_em_caps",
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_counter_fyn1668-sft_tso_turner_em_caps/iter_0000099/hf":     "120B fyn1668-SFT Counter turner_em_caps",

    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_fyn1668-sft_tso_turner_em_shakespearean/iter_0000078/hf":          "120B fyn1668-SFT TSO     turner_em_shakespearean",
