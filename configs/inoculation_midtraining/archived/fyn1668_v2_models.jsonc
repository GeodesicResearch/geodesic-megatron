    // ─────────────────────────────────────────────────────────────────────────

    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_fyn1668-sft_tso_sft_v2/iter_0000250/hf":              "120B fyn1668-SFT TSO     SFT_v2",
    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_counter_fyn1668-sft_tso_sft_v2/iter_0000250/hf":      "120B fyn1668-SFT Counter SFT_v2",

    "/projects/a5k/public/checkpoints/megatron/im_nemotron_120b_fyn1668-sft_tso_turner_em_default/iter_0000073/hf":          "120B fyn1668-SFT TSO     turner_em_default",
